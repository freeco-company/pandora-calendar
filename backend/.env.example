APP_NAME=PandoraCalendar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# 集團整合 (P1+, prod required)
# ============================================================================

# Pandora Core Identity (ADR-007) - P1 切換 IDENTITY_DRIVER=http 才接 prod
# Phase 0: mock (本機 SQLite User table)
# P1+:     http (走 Pandora Core, PII 不落地)
IDENTITY_DRIVER=mock
PANDORA_CORE_BASE_URL=
PANDORA_CORE_INTERNAL_SECRET=

# 集團 Gamification publisher (ADR-009) - 空 = noop, 設了走 HTTP outbox
# 對應 py-service freeco-company/pandora-core-conversion
PANDORA_GAMIFICATION_BASE_URL=
PANDORA_GAMIFICATION_INTERNAL_SECRET=
PANDORA_GAMIFICATION_APP_ID=pandora_calendar

# Conversion / 加盟漏斗 publisher (ADR-003 / ADR-008)
# Lifecycle 訊號送母艦 lead pool — App 內 zero 顯示
PANDORA_CONVERSION_BASE_URL=
PANDORA_CONVERSION_INTERNAL_SECRET=
PANDORA_CONVERSION_APP_ID=pandora_calendar

# ============================================================================
# 訂閱 / IAP (P2 上架收費)
# ============================================================================

# Free vs Premium 切分點
FREE_DODO_CHECKIN_PER_DAY=1
FREE_HISTORY_MONTHS=12

# Apple App Store IAP
# - Shared secret from App Store Connect → My Apps → App Information
# - Apple Root CA G3 fingerprint allowlist (default ok, only override for sandbox testing)
APPLE_IAP_SHARED_SECRET=
# APPLE_ACCEPTED_ROOTS=63343abfb89a6a03eeb88e921e5c22d776675316d9967b1f0fea9d8fc71f2fc3

# Google Play Billing
# - 完整 service account JSON (inline) 或 file://path/to/sa.json
# - Service account 必須有 Android Publisher API 權限 (在 Play Console → Users)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ECPay 定期定額 (Web fallback / 退費 / 客服管道)
# 從 ECPay 商家後台拿; prod / staging / sandbox 是不同組
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=


APP_NAME=PandoraCalendar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ============================================================================
# 集團整合 (P1+, prod required)
# ============================================================================

# Pandora Core Identity (ADR-007)
# 註：舊 IDENTITY_DRIVER=mock|http 切換已取消（PC 端 lookup API 從未實作）。
# 現況：dev / testing 走 sanctum demo login（/api/demo/login 僅在 non-prod 開放）；
# prod 走 Authorization: Bearer <PC-issued JWT>，由 PandoraJwtAuth middleware
# + PlatformJwtVerifier (RS256) 驗 iss/aud/exp/nbf + IdentityClient::resolveFromJwt
# 自動建 minimal mirror（uuid only，PII 不落地）。
# Webhook user.upserted 由 PC 推來再補 display_name / avatar_url / subscription_tier。
#
# IDENTITY_DRIVER 欄位保留向後相容（讀 config 不會炸），但實際無作用。
IDENTITY_DRIVER=mock
PANDORA_CORE_BASE_URL=
PANDORA_CORE_INTERNAL_SECRET=
# JWT verify 預設值；prod 上需確認 issuer / audience 與 PC 簽出 token 一致
PANDORA_CORE_JWT_ISSUER=pandora-core
PANDORA_CORE_JWT_AUDIENCE=fairy-calendar
PANDORA_CORE_WEBHOOK_SECRET=

# 集團 Gamification publisher + webhook (ADR-009 P5)
# 對應 py-service freeco-company/pandora-core-conversion
# enabled=false 時走 NoopGamificationPublisher（仍寫 outbox，但不 push）
PANDORA_GAMIFICATION_ENABLED=false
PANDORA_GAMIFICATION_BASE_URL=
PANDORA_GAMIFICATION_INTERNAL_SECRET=
# 集團共用 HMAC secret（py-service / mother / meal / calendar 同一把）
PANDORA_GAMIFICATION_HMAC_SECRET=
# 預設 = HMAC_SECRET，若需要分離 inbound/outbound 才另填
PANDORA_GAMIFICATION_WEBHOOK_SECRET=
PANDORA_GAMIFICATION_WEBHOOK_WINDOW_SECONDS=300
PANDORA_GAMIFICATION_APP_ID=pandora_calendar
PANDORA_GAMIFICATION_QUEUE_CONNECTION=
PANDORA_GAMIFICATION_QUEUE_NAME=default
PANDORA_GAMIFICATION_APP_OPENED_DAILY_CAP=3

# Conversion / 加盟漏斗 publisher (ADR-003 / ADR-008)
# Lifecycle 訊號送母艦 lead pool — App 內 zero 顯示
PANDORA_CONVERSION_BASE_URL=
PANDORA_CONVERSION_INTERNAL_SECRET=
PANDORA_CONVERSION_APP_ID=pandora_calendar

# ============================================================================
# 朵朵 LLM (P4 個人化對白 — pluggable，無 key 時 fallback DodoDialogLibrary)
# ============================================================================
# Provider: null | openai | claude
# - null（預設）：永遠用 library 對白變體，零成本，上架不阻塞
# - openai：gpt-4o-mini，~$0.0002/次對白，$0.05/user/day cap = 250 次
# - claude：claude-haiku-4-5，~$0.0003/次對白
LLM_PROVIDER=null
LLM_TIMEOUT=8
LLM_MAX_RETRIES=1
LLM_CACHE_TTL=0
LLM_USER_DAILY_CAP=0.05
LLM_PREMIUM_USER_DAILY_CAP=0.20

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com/v1

ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# ============================================================================
# 訂閱 / IAP (P2 上架收費)
# ============================================================================

# Free vs Premium 切分點
FREE_DODO_CHECKIN_PER_DAY=1
FREE_HISTORY_MONTHS=12

# Apple App Store IAP
# - Shared secret from App Store Connect → My Apps → App Information
# - Apple Root CA G3 fingerprint allowlist (default ok, only override for sandbox testing)
APPLE_IAP_SHARED_SECRET=
# APPLE_ACCEPTED_ROOTS=63343abfb89a6a03eeb88e921e5c22d776675316d9967b1f0fea9d8fc71f2fc3

# Google Play Billing
# - 完整 service account JSON (inline) 或 file://path/to/sa.json
# - Service account 必須有 Android Publisher API 權限 (在 Play Console → Users)
GOOGLE_PLAY_SERVICE_ACCOUNT_JSON=

# ECPay 定期定額 (Web fallback / 退費 / 客服管道)
# 從 ECPay 商家後台拿; prod / staging / sandbox 是不同組
ECPAY_MERCHANT_ID=
ECPAY_HASH_KEY=
ECPAY_HASH_IV=

# ============================================================================
# Sentry — Crash reporting / performance
# ============================================================================
# DSN 為空時 SDK noop（dev / test 不送）
# ⚠️ Pandora Calendar 隱私紅線：health 路徑（/cycles, /symptoms, /bbt, /pms, /pregnancy,
#   /body-rhythm, /dodo/checkin, /insights）被 HealthDataScrubber 整段 drop；
#   request body / cookies / IP / authenticated user 永遠不上送
SENTRY_LARAVEL_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_SAMPLE_RATE=1.0
SENTRY_SEND_DEFAULT_PII=false
SENTRY_ENVIRONMENT=
SENTRY_RELEASE=

# ============================================================================
# Push Notifications — pluggable, env-driven
# ============================================================================
# 缺 credential 時對應 channel 自動 noop（只 log info），不擋上架。
# Health-data 禁進 push body（push body 從 push-templates.php 121 variant 池抓，已過合規）。

# Web Push (VAPID) — 既有 PUSH_VAPID_* 沿用；新環境變數可寫 WEBPUSH_*（先讀 WEBPUSH_，fallback PUSH_VAPID_）
PUSH_VAPID_SUBJECT=
PUSH_VAPID_PUBLIC_KEY=
PUSH_VAPID_PRIVATE_KEY=
# WEBPUSH_VAPID_SUBJECT=mailto:support@js-store.com.tw
# WEBPUSH_VAPID_PUBLIC_KEY=
# WEBPUSH_VAPID_PRIVATE_KEY=

# FCM (Android) — HTTP v1 + OAuth2 service account
# 從 Firebase Console → Project Settings → Service accounts → Generate new private key (JSON)
FCM_PROJECT_ID=
FCM_CREDENTIALS_PATH=

# APNs (iOS) — HTTP/2 + JWT (.p8 key)
# 從 Apple Developer Portal → Keys → 建一把 APNs Auth Key 拿到 .p8
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_PRIVATE_KEY_PATH=
APNS_BUNDLE_ID=com.jerosse.pandora.calendar
APNS_SANDBOX_MODE=false


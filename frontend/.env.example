# Pandora Calendar — frontend (Vite + Capacitor) env
# 跟 backend 一樣，DSN 為空時 SDK noop（dev / test 不送）
#
# ⚠️ Pandora Calendar 隱私紅線（CLAUDE.md）：
#   health 路徑（/cycles, /symptoms, /bbt, /pms, /pregnancy, /body-rhythm,
#   /dodo/checkin, /insights）被 lib/sentry.ts 的 beforeSend / beforeBreadcrumb
#   整段 drop；request body / cookies 永遠不上送；user context 只留 uuid id
VITE_SENTRY_DSN=
VITE_APP_VERSION=

# Backend API base
VITE_API_BASE_URL=http://localhost:8000

{
  "appId": "com.jerosse.pandora.calendar",
  "appName": "潘朵拉月曆",
  "webDir": "dist",
  "server": {
    "cleartext": false,
    "allowNavigation": [
      "calendar-api.js-store.com.tw",
      "id.js-store.com.tw",
      "pandora.js-store.com.tw",
      "*.pandora.js-store.com.tw",
      "*.js-store.com.tw"
    ]
  },
  "ios": {
    "contentInset": "automatic",
    "scrollEnabled": true,
    "backgroundColor": "#fbf6ee",
    "scheme": "pandoracalendar"
  },
  "android": {
    "backgroundColor": "#fbf6ee",
    "scheme": "pandoracalendar"
  },
  "plugins": {
    "App": {
      "_comment": "Custom URL scheme pandoracalendar:// 給 OAuth callback 用 — Pandora Core /v1/auth/oauth/{provider}/callback 在 mobile 模式應 redirect 到 pandoracalendar://oauth/callback?token=...，App 用 listenForLaunchUrl 接住"
    },
    "BiometricAuth": {
      "androidMaxAttempts": 3,
      "androidBiometryStrength": "weak",
      "iosFallbackTitle": "使用密碼"
    }
  }
}
